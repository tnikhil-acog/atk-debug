{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "node"], 
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts", "examples/**/*.ts", "test/**/*.ts"]
}
